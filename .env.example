# ─── Better Auth ──────────────────────────────────────────────────────
# Secret used to sign session cookies and tokens (min 32 chars).
# Generate via: openssl rand -base64 32
BETTER_AUTH_SECRET=
# The public URL of your app (used for origin validation and redirects).
BETTER_AUTH_URL=http://localhost:3000

# ─── Microsoft OAuth (Better Auth) ──────────────────────────────────────
# Required for "Sign in with Microsoft" on the login page.
# Create an app registration in the Azure Portal:
#   https://portal.azure.com -> App registrations -> New registration
# - Redirect URI: http://localhost:3000/api/auth/callback/microsoft (dev)
# - Supported account types: "Accounts in any organizational directory"
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

# ─── Stripe ─────────────────────────────────────────────────────────────
# Required for merchandise checkout and donations.
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# Create a webhook endpoint in Stripe Dashboard:
#   https://dashboard.stripe.com/webhooks
# - Endpoint URL: http://localhost:3000/api/stripe-webhook (dev)
# - Events: checkout.session.completed
# Then copy the signing secret here:
STRIPE_WEBHOOK_SECRET=

# ─── Database ────────────────────────────────────────────────────────────
# Optional. Defaults to a local SQLite file (jmpls.db) in the app root.
# Set this to a Turso/libSQL remote URL for production deployments.
# DB_URL=libsql://my-database.turso.io
